# =============================================================================
# Project & Task Management API - Environment Variables
# =============================================================================
# Copy this file to ".env" and fill in the values for your environment.
#   cp .env.example .env
# =============================================================================

# ----- Application -----
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# ----- i18n (Localization) -----
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ar

# ----- JWT -----
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=1h

# ----- Bcrypt -----
BCRYPT_SALT_ROUNDS=10

# ----- PostgreSQL (Docker Compose will use these) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=project_task_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ----- Database URL (optional - takes precedence over individual PG vars) -----
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_task_db?schema=public

# ----- Logging -----
LOG_LEVEL=debug

# ----- Seeder (optional - used by `npm run seed`) -----
# Override the default admin user created by the admin seeder.
# If unset, defaults to: admin@projecttask.com / Admin@12345
# ADMIN_NAME=System Admin
# ADMIN_EMAIL=admin@projecttask.com
# ADMIN_PASSWORD=Admin@12345
