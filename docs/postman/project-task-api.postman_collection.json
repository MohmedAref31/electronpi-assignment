    {
      "name": "Tasks",
      "description": "Task management endpoints. Create and list tasks are nested under projects (/projects/:projectId/tasks). Get, update, and delete single tasks are flat (/tasks/:id). All requests require a Bearer token. List supports filtering by status and priority plus pagination.",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.data && json.data.task) {",
                  "  pm.environment.set('taskId', json.data.task.id);",
                  "  console.log('taskId stored: ' + json.data.task.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement login screen\",\n  \"description\": \"Build the login UI with form validation\",\n  \"status\": \"pending\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2026-02-15T00:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"]
            },
            "description": "Create a task under a project owned by the authenticated user. Returns 201. The test script auto-stores the task ID in {{taskId}}."
          },
          "response": [
            {
              "name": "Created",
