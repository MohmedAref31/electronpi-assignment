    {
      "name": "Projects",
      "description": "Project management endpoints for the authenticated user. Users can create, list, view, update, and delete their own projects. All requests require a Bearer token.",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.data && json.data.project) {",
                  "  pm.environment.set('projectId', json.data.project.id);",
                  "  console.log('projectId stored: ' + json.data.project.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Website\",\n  \"description\": \"Redesign the company website\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["projects"]
