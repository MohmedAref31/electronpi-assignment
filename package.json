{
  "name": "project-task-api",
  "version": "1.0.0",
  "description": "Project & Task Management RESTful API - ElectroPi Backend Node.js Developer Assessment",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migration:generate": "npx typeorm migration:generate -d dist/data-source.js",
    "migration:create": "npx typeorm migration:create",
    "migration:run": "npx typeorm migration:run -d dist/data-source.js",
    "migration:revert": "npx typeorm migration:revert -d dist/data-source.js",
    "seed": "ts-node src/seeds/run-seeders.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "keywords": [
    "express",
    "typescript",
    "typeorm",
    "postgresql",
    "jwt",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "accept-language-parser": "^1.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "i18next": "^26.3.1",
    "i18next-fs-backend": "^2.6.6",
    "i18next-http-middleware": "^3.9.7",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/accept-language-parser": "^1.5.8",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
